# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MongoDB connection string (Atlas or local)
# Atlas example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/greenday
# Local example: mongodb://localhost:27017/greenday
MONGODB_URI=mongodb+srv://sakaleshronad50_db_user:sakalesh2004@cluster0.3vthiue.mongodb.net/?appName=Cluster0

# Google OAuth 2.0 credentials (from Google Cloud Console)
# Authorized redirect URI must include: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# JWT signing secret — use a long random string in production
JWT_SECRET="change_me_to_a_long_random_secret"

# URL where the frontend is served
APP_URL="http://localhost:3000"
