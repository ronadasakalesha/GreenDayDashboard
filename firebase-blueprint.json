{
  "entities": {
    "DailyLog": {
      "title": "Daily Log",
      "description": "A daily performance and habit tracking entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the log entry." },
        "date": { "type": "string", "format": "date", "description": "ISO date string (YYYY-MM-DD)." },
        "performance": { "type": "number", "description": "Performance score (-10 to 10)." },
        "emotions": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of emotions felt during the day."
        },
        "notes": { "type": "string", "description": "Daily reflection notes." },
        "disciplineScore": { "type": "number", "description": "Score from 0 to 100." },
        "habits": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "completed": { "type": "boolean" }
            },
            "required": ["id", "completed"]
          }
        },
        "uid": { "type": "string", "description": "Owner's user ID." }
      },
      "required": ["id", "date", "performance", "emotions", "disciplineScore", "habits", "uid"]
    },
    "Habit": {
      "title": "Habit Definition",
      "description": "A habit that the user tracks.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "name", "icon", "color", "uid"]
    }
  },
  "firestore": {
    "/users/{userId}/logs/{logId}": {
      "schema": "DailyLog",
      "description": "User's daily performance logs."
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": "Habit",
      "description": "User's custom habit definitions."
    }
  }
}
